<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>

<VBox xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" fx:controller="com.mycompany.prova.csf.PrimaryController" >
   <children>
       <Label fx:id="titulo" text="SISTEMA DE LOGIN" />  
        <TextField fx:id="nome" promptText="Nome" maxWidth="150"  />
        <TextField fx:id="Senha" promptText="Senha" maxWidth="150" />
        <HBox spacing="10.0" alignment="CENTER" >
        <Button fx:id="secondaryButton" text="Fazer login" onAction="#switchToSecondary" />
        <Button fx:id="cad" text="cadastro" onAction="#cadastro" />
        <Button fx:id="rec" text="recuperar senha" onAction="#rec" />
        </HBox>
        <Label fx:id="mensagem" text="" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
