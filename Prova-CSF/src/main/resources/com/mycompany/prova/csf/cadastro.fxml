<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<VBox xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" fx:controller="com.mycompany.prova.csf.CadastroController">
   <children>
        <TextField fx:id="nome" promptText="Nome" />
        <TextField fx:id="senha" promptText="Senha"/>
        <CheckBox fx:id="termos" text="Aceito os termos de uso"/> 
        <ChoiceBox fx:id="perfil"/>
         <Label fx:id="mensagem" text="" />
        <Button fx:id="enviar" text="enviar" onAction="#adicionar"/>  
        <Button fx:id="volt" text="voltar" onAction="#switchToPrimary"/>  
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>